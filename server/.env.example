# ── Core ───────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/founderstv
JWT_SECRET=your_super_secret_jwt_key_here
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# ── Google OAuth (free) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Apple Sign In (requires paid Apple Developer account) ──────────
# Leave blank until you have an Apple Developer account + Service ID + key.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── Email magic link (Resend — free tier) ──────────────────────────
# If blank, magic links are printed to the server console instead of emailed.
RESEND_API_KEY=
EMAIL_FROM=FoundersTV <onboarding@resend.dev>

# ── Cloudinary (profile photos) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── TURN server (WebRTC behind firewalls — optional) ───────────────
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
